{
  "name": "arroyo-marketing-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "check": "node scripts/check-site.js",
    "test": "node --test tests/*.test.mjs",
    "build": "npm run check && node scripts/build-site.js",
    "check:all": "npm test && npm run build",
    "research:agencies": "node scripts/research-agency-sites.mjs",
    "dev:cloudflare": "npm run build && wrangler pages dev dist",
    "deploy:cloudflare": "npm run check:all && wrangler pages deploy dist --project-name=arroyo-marketing"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "wrangler": "4.110.0"
  }
}
